# ============================================================
#  CHATBOT NLP — .gitignore
# ============================================================

# ---------------------------
# 🔐 ENVIRONMENT / SECRETS
# ---------------------------
.env
.env.*
!.env.example

# ---------------------------
# 🐍 PYTHON / BACKEND
# ---------------------------
venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
*.egg
*.log

# ---------------------------
# 📁 UPLOADS (file dari user)
# ---------------------------
backend/uploads/*
!backend/uploads/.gitkeep

# ---------------------------
# ⚙️ NODE / FRONTEND
# ---------------------------
node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp/
.pnp.js

# Build output
frontend/dist/
frontend/build/
frontend/.vite/

# ---------------------------
# 💻 OS & EDITOR
# ---------------------------
.DS_Store
Thumbs.db
desktop.ini
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ---------------------------
# 🗄️ DATABASE
# ---------------------------
*.db
*.sqlite
*.sqlite3
