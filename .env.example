# --- Database ---
DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=chatbot_nlp

# --- JWT ---
JWT_SECRET_KEY=your_jwt_secret_key_here

# --- Google Gemini API ---
GEMINI_API_KEY=your_gemini_api_key_here
